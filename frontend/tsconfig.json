        "outDir": "./public",
        "rootDir": "./",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true
    },
    "include": [
        "dashboard.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}