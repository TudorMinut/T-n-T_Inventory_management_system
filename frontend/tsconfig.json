{
    "compilerOptions": {
        "target": "ES6",
        "module": "ESNext",
        "outDir": "../backend/dist/frontend/public",
        "rootDir": "./",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "noEmit": false,
        "noEmitOnError": false,
        "moduleResolution": "node",
        "allowSyntheticDefaultImports": true
    },
    "include": [
        "dashboard.ts",
        "admin.ts",
        "login.ts",
        "statistics.ts",
        "newFile1.ts",
        "newFile2.ts",
        "newFile3.ts",
        "auth.ts",
        "src/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "**/*.js"
    ]
}