{
    "compilerOptions": {
        "target": "ES2017",
        "module": "none",
        "lib": [
            "ES2017",
            "DOM"
        ],
        "outDir": ".",
        "strict": false,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": [
        "*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}